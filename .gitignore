# Reference implementations (studied, not part of NoirRail source)
.reference/

# Rust
/contracts/target/
/cli/target/
target/
**/*.rs.bk

# Node
node_modules/
.pnpm-store/
.next/
out/
dist/
*.tsbuildinfo

# Circuit build artifacts (regenerated by `pnpm circuits:build`)
circuits/build/
circuits/**/*.r1cs
circuits/**/*.sym
circuits/**/*_js/

# Trusted-setup artifacts (large; ceremony output is published separately)
circuits/ceremony/*.ptau
circuits/ceremony/*.zkey
!circuits/ceremony/*_final.zkey.sha256
# Verification keys ARE committed (small, public, pinned on-chain)
!circuits/ceremony/**/verification_key.json

# Generated proofs / witnesses / scratch
.demo/
*.wtns
proof.json
public.json
*_hex.txt
withdrawal_input.json
demo_*.json

# Secrets & local config
.env
.env.local
*.key
.stellar/
deployments/local.json

